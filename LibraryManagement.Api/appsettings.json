{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "YOUR_CONNECTION_STRING"
  },
  "JwtSettings": {
    "Key": "YOUR_SECRET_KEY",
    "ValidIssuer": "YOUR_AUDIENCE",
    "ValidAudiences": "YOUR_ISSUER",
    "Expires": 180
  }
}
